# ====================================================================
# ResilientAI Environment Variables
# ====================================================================

# ─── API & App Configuration ────────────────────────────────────
API_HOST=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
USE_SEED_DATA=true                          # true = use mock data (safe for demo)
DEMO_MODE=true
DEMO_SCENARIO=hormuz_disruption

# ─── AI Models & Services ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here     # Get from Google AI Studio
NEBIUS_API_KEY=your_nebius_api_key_here     # Get from Nebius AI
NEWS_API_KEY=your_newsapi_key_here          # Get from newsapi.org (free tier ok)

# ─── Database (Supabase) ────────────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_service_key_here

# ─── Quantum Computing ──────────────────────────────────────────
IBM_QUANTUM_TOKEN=your_ibm_token_here       # Get from quantum.ibm.com (free)
QUANTUM_TIMEOUT_SECONDS=10                  # fallback to classical after this

# ─── Messaging (WhatsApp / Meta) ───────────────────────────────
WHATSAPP_TOKEN=your_meta_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id_here

# ─── Mapping & Location (Frontend) ──────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here
